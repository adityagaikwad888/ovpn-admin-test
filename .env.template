# =============================================================================
# OpenVPN Admin Panel Environment Configuration Template
# =============================================================================
# Copy this file to .env and modify the values according to your setup
# All variables are required unless marked as optional

# =============================================================================
# OpenVPN Server Network Configuration
# =============================================================================

# EasyRSA Certificate Expiry - Lifetime (in days) for newly issued certificates
# This controls how long server and client certificates are valid before expiry.
# Example: "365" = 1 year, "1825" = 5 years, "3650" = 10 years
# Note: CA expiry is set separately during CA creation.
EASYRSA_CERT_EXPIRY=365

# VPN Client Network Range - Network address for VPN clients
# This is the subnet that will be assigned to VPN clients when they connect
# Example: "10.8.0.0" (clients get IPs like 10.8.0.2, 10.8.0.3, etc.)
OVPN_SERVER_NET="10.8.0.0"

# VPN Client Network Mask - Subnet mask for the VPN client network
# Defines how many IP addresses are available for VPN clients
# "255.255.255.0" = /24 subnet = ~250 available client IPs
OVPN_SERVER_MASK="255.255.255.0"

# Enable Password Authentication - Adds username/password auth on top of certificates
# "true" = Two-factor auth (certificate + password), "false" = certificate only
# Recommended: "true" for production environments
OVPN_PASSWD_AUTH="true"

# Custom Routes - Additional network routes pushed to VPN clients
# Format: "network_address subnet_mask" (space-separated)
# Example: "172.20.0.0 255.255.0.0" allows clients to access Docker internal network
# Leave empty ("") if no custom routes needed
OVPN_CUSTOM_ROUTES="172.20.0.0 255.255.0.0"

# Docker Internal Network - The Docker bridge network CIDR
# Must match the network defined in docker-compose.yaml
# Used for iptables rules to allow VPN clients access to containers
DOCKER_NETWORK="172.20.0.0/16"

# =============================================================================
# Network Optimization Settings
# =============================================================================

# Tunnel MTU - Maximum Transmission Unit for the VPN tunnel interface
# Lower values prevent packet fragmentation, higher values improve performance
# "1372" = Optimized for most networks, "1500" = Standard Ethernet MTU
OVPN_TUN_MTU="1372"

# MSS Fix - TCP Maximum Segment Size clamping to prevent fragmentation
# Should be MTU minus 40 bytes (TCP/IP headers)
# "1332" = 1372 - 40, prevents TCP fragmentation issues
OVPN_MSSFIX="1332"

# =============================================================================
# OpenVPN Admin Interface Configuration
# =============================================================================

# Debug Mode - Enable detailed debug logging in ovpn-admin
# "true" = Verbose debug output, "false" = Standard logging
# Recommended: "true" for setup/troubleshooting, "false" for production
OVPN_DEBUG="true"

# Verbose Mode - Enable verbose output in ovpn-admin operations
# "true" = Detailed operation logs, "false" = Minimal output
OVPN_VERBOSE="true"

# VPN Network CIDR - The VPN network in CIDR notation
# Must match OVPN_SERVER_NET/OVPN_SERVER_MASK above
# Example: "10.8.0.0/24" corresponds to net=10.8.0.0 mask=255.255.255.0
OVPN_NETWORK="10.8.0.0/24"

# Client Config Directory - Enable per-client configuration files
# "true" = Enable CCD (allows custom settings per client)
# "false" = All clients use same configuration
OVPN_CCD="true"

# CCD Path - Internal container path for client config directory
# Default: "/mnt/ccd" (mapped to ./ccd_master/ on host)
# Only change if you modify volume mappings
OVPN_CCD_PATH="/mnt/ccd"

# EasyRSA Path - Internal container path for certificate storage
# Default: "/mnt/easyrsa" (mapped to ./easyrsa_master/ on host)
# Contains all PKI certificates, keys, and CA data
EASYRSA_PATH="/mnt/easyrsa"

# =============================================================================
# Public Server Configuration
# =============================================================================

# OpenVPN Server Address - **CRITICAL**: Your server's public IP and port
# Format: "IP_ADDRESS:PORT:PROTOCOL"
# MUST be your actual public IP that clients can reach
# Example: "203.0.113.10:7777:udp" or "vpn.example.com:7777:udp"
# ⚠️  CHANGE THIS TO YOUR SERVER'S PUBLIC IP ADDRESS ⚠️
OVPN_SERVER="YOUR_PUBLIC_IP:7777:udp"

# =============================================================================
# Certificate and Authentication Paths
# =============================================================================

# Certificate Index Path - Location of EasyRSA certificate index file
# Default: "/mnt/easyrsa/pki/index.txt"
# Contains list of all issued certificates and their status
OVPN_INDEX_PATH="/mnt/easyrsa/pki/index.txt"

# Authentication Database - Enable user database for password auth
# Must be "true" if OVPN_PASSWD_AUTH="true"
# "false" only if using certificate-only authentication
OVPN_AUTH="true"

# User Database Path - Location of password authentication database
# Default: "/mnt/easyrsa/pki/users.db"
# SQLite database containing usernames and encrypted passwords
OVPN_AUTH_DB_PATH="/mnt/easyrsa/pki/users.db"

# =============================================================================
# Logging Configuration
# =============================================================================

# Log Level - Controls verbosity of application logging
# Values: "trace", "debug", "info", "warn", "error"
# "debug" = Detailed logs for troubleshooting
# "info" = Standard operational logs
# "warn" = Warnings and errors only
LOG_LEVEL="debug"

# =============================================================================
# Configuration Notes and Examples
# =============================================================================

# Network Planning Example:
# - Docker Network: 172.20.0.0/16 (containers communicate)
# - VPN Network: 10.8.0.0/24 (VPN clients get these IPs)
# - Custom Routes: Allow VPN clients to access Docker containers

# Security Recommendations:
# 1. Set OVPN_PASSWD_AUTH="true" for production
# 2. Use strong passwords in the user database
# 3. Regularly rotate certificates
# 4. Monitor LOG_LEVEL="debug" logs for suspicious activity

# Performance Tuning:
# 1. Adjust OVPN_TUN_MTU based on your network (1372-1500)
# 2. Set OVPN_MSSFIX to MTU minus 40
# 3. Use UDP protocol for better VPN performance
# 4. Monitor connection logs for fragmentation issues

# Required Changes Before First Use:
# 1. ⚠️  Update OVPN_SERVER with your public IP address
# 2. Verify DOCKER_NETWORK matches docker-compose.yaml
# 3. Adjust network ranges if they conflict with existing networks
# 4. Set appropriate LOG_LEVEL for your environment

# =============================================================================
